# ──────────────────────────────────────────────────────────────
# AeroMat — example environment variables
# Copy to `.env.local` and fill in real values.
# Public (NEXT_PUBLIC_*) vars are exposed to the browser.
# ──────────────────────────────────────────────────────────────

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
# Get from: GA4 Admin → Data streams → Web → Measurement ID
# When empty, GA loader returns null (no script loaded, no requests).
NEXT_PUBLIC_GA_ID=

# ──────────────────────────────────────────────────────────────
# Formularz kontaktowy — wysylka e-mail przez Resend (https://resend.com)
# Bez RESEND_API_KEY i RESEND_FROM_EMAIL formularz nie wysle wiadomosci.
# ──────────────────────────────────────────────────────────────

# Klucz API do Resend (format: re_xxxxxxxx). Z panelu Resend → API Keys.
RESEND_API_KEY=

# Adres nadawcy (musi byc w domenie zweryfikowanej w Resend), np. kontakt@twojadomena.pl
RESEND_FROM_EMAIL=

# Adres odbiorcy zgloszen z formularza. Gdy pusty — uzywany jest RESEND_FROM_EMAIL.
CONTACT_EMAIL=
